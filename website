<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HigherMed Corporation</title>
<link rel="stylesheet" href="style.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>

<header>
    <div class="container">
        <h2 class="logo">HigherMed</h2>

        <nav>
            <a href="#home">Home</a>
            <a href="#about">About</a>
            <a href="#services">Services</a>
            <a href="#contact">Contact</a>
        </nav>
    </div>
</header>

<section id="home" class="hero">
    <div class="hero-content">
        <h1>Advancing Critical Care Solutions</h1>

        <p>
            Delivering innovative ICU and respiratory care solutions
            that help hospitals provide exceptional patient care.
        </p>

        <div class="hero-buttons">
            <a href="#services" class="btn primary">Our Services</a>
            <a href="#contact" class="btn secondary">Contact Us</a>
        </div>
    </div>
</section>

<section id="about" class="section">
    <div class="container">
        <h2>About Us</h2>

        <p>
            HigherMed Corporation is dedicated to providing hospitals
            and healthcare facilities with high-quality ICU and respiratory
            care solutions. Our mission is to support healthcare professionals
            through reliable equipment, technical expertise, and responsive
            customer service.
        </p>
    </div>
</section>

<section id="services" class="section gray">
    <div class="container">
        <h2>Our Services</h2>

        <div class="cards">

            <div class="card">
                <h3>ICU Solutions</h3>
                <ul>
                    <li>ICU Planning & Design</li>
                    <li>Equipment Supply</li>
                    <li>ICU Expansion Projects</li>
                    <li>Installation & Commissioning</li>
                </ul>
            </div>

            <div class="card">
                <h3>Respiratory Care</h3>
                <ul>
                    <li>Ventilators</li>
                    <li>Monitoring Systems</li>
                    <li>Oxygen Therapy Solutions</li>
                    <li>Clinical Support</li>
                </ul>
            </div>

            <div class="card">
                <h3>Technical Support</h3>
                <ul>
                    <li>Preventive Maintenance</li>
                    <li>Troubleshooting</li>
                    <li>Technical Consultation</li>
                    <li>Service Coordination</li>
                </ul>
            </div>

        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <h2>Why Choose HigherMed?</h2>

        <div class="cards">

            <div class="card center">
                <h3>Industry Expertise</h3>
            </div>

            <div class="card center">
                <h3>Reliable Solutions</h3>
            </div>

            <div class="card center">
                <h3>Responsive Support</h3>
            </div>

            <div class="card center">
                <h3>Commitment to Patient Care</h3>
            </div>

        </div>
    </div>
</section>

<section id="contact" class="section contact">
    <div class="container">

        <h2>Contact Us</h2>

        <div class="contact-info">

            <p><strong>HigherMed Corporation</strong></p>

            <p>📧 madridbennett@gmail.com</p>

            <p>📞 +63 998 929 0603</p>

        </div>

        <form class="contact-form">
            <input type="text" placeholder="Your Name" required>
            <input type="email" placeholder="Your Email" required>
            <textarea rows="5" placeholder="Your Message"></textarea>

            <button type="submit">Send Message</button>
        </form>

    </div>
</section>

<footer>
    <p>© 2026 HigherMed Corporation. All Rights Reserved.</p>
</footer>

<script src="script.js"></script>

</body>
</html>
